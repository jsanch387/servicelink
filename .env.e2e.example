# Copy to `.env.e2e.local` (gitignored) for Playwright E2E tests.
# Use a dedicated test business account — not your personal login.

# App URL (default: local dev)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Dashboard owner with onboarding completed (can access /dashboard/marketing)
E2E_OWNER_EMAIL=urbanink.help@gmail.com
E2E_OWNER_PASSWORD=Test1234

# Public booking slug (optional). Prefer omit — tests resolve from owner dashboard after login.
# E2E_PUBLIC_BUSINESS_SLUG=your-business-slug
